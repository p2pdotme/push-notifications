# ---------------------------------------------------------------------------
# p2p.me self-hosted push notification service — example configuration
# Copy to `.env` and fill in. NEVER commit the real .env file.
# ---------------------------------------------------------------------------

# HTTP server
PORT=4000
HOST=0.0.0.0

# Comma-separated list of allowed CORS origins for browser-facing endpoints
# (subscribe / public key). Use "*" only for local development.
# e.g. https://app.p2p.me,https://merchant.p2p.me
CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# VAPID keys — generate once with `npm run generate-vapid`.
# The public key is shared with browsers; the private key MUST stay secret.
# ---------------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI for push services. Must be a mailto: or https: URL.
VAPID_SUBJECT=mailto:dev@p2p.me

# ---------------------------------------------------------------------------
# Storage — SQLite file path. Use an absolute path / mounted volume in prod.
# ---------------------------------------------------------------------------
DATABASE_PATH=./data/push.sqlite

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# Admin key: can send to / manage any app. Keep this very secret.
ADMIN_API_KEY=change-me-admin-key

# Per-app API keys as JSON: { "<appId>": "<secret key>" }
# Each org app gets its own key so it can only send to its own subscribers.
APP_KEYS={"user-app":"change-me-user-app-key","merchant-app":"change-me-merchant-app-key"}

# How many consecutive delivery failures before a subscription is disabled.
MAX_FAILURES=5

# ---------------------------------------------------------------------------
# Admin dashboard auth (no third-party SDK — SIWE via ox, sessions via HS256)
# ---------------------------------------------------------------------------
AUTH_DOMAIN=admin.push.p2p.me          # was THIRDWEB_AUTH_DOMAIN (still accepted)
AUTH_JWT_SECRET=<32+ random bytes>     # was THIRDWEB_AUTH_PRIVATE_KEY (still accepted)

# NOTE: THIRDWEB_AUTH_DOMAIN and THIRDWEB_AUTH_PRIVATE_KEY still work as fallbacks.
# THIRDWEB_SECRET_KEY is no longer used by the server.

# Comma-separated bootstrap admin wallet addresses (embedded-wallet addresses).
ADMIN_WALLETS=
# Origin of the dashboard SPA, allowed to call /auth and /admin with credentials.
DASHBOARD_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# Runtime tuning (optional — defaults shown)
# ---------------------------------------------------------------------------
SEND_CONCURRENCY=25                    # max push sends in flight at once
LOG_RETENTION_DAYS=0                   # 0 = keep delivery logs forever

# NOTE: APP_KEYS and CORS_ORIGINS above are now OPTIONAL. They are imported into
# the database once on first boot; afterward the dashboard is the source of truth.
