{
  "name": "@p2pdotme/push-notifications",
  "version": "0.1.0",
  "description": "Lightweight self-hosted Web Push (VAPID) notification service for the p2p.me organization. No Firebase, no third-party vendors.",
  "license": "MIT",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "push-vapid-keys": "dist/scripts/generate-vapid.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "dev": "tsx watch src/index.ts",
    "generate-vapid": "tsx scripts/generate-vapid.ts",
    "test": "node --test --import tsx ./test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ox": "^0.7.2",
    "thirdweb": "^5.120.1",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
