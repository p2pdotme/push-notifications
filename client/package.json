{
  "name": "@p2pdotme/push-client",
  "version": "0.2.0",
  "description": "Framework-agnostic browser client for the p2p.me self-hosted push notification service.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./service-worker.js": "./service-worker.js"
  },
  "files": [
    "dist",
    "service-worker.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/p2pdotme/push-notifications.git",
    "directory": "client"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "typescript": "^5.7.3"
  }
}
