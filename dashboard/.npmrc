# Install @p2pdotme-scoped packages (e.g. @p2pdotme/push-client) from the
# private GitHub Packages registry. The token is NOT stored here — npm expands
# ${GITHUB_TOKEN} from the environment at install time. On Netlify, set
# GITHUB_TOKEN in Site settings → Environment variables (a GitHub PAT with the
# read:packages scope). Locally, export it in your shell.
@p2pdotme:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
